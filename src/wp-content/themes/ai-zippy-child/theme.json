{
	"$schema": "https://schemas.wp.org/wp/6.7/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"layout": {
			"contentSize": "1440px",
			"wideSize": "100%"
		},
		"color": {
			"palette": [
				{
					"slug": "primary",
					"color": "#d50017",
					"name": "Primary"
				},
				{
					"slug": "secondary",
					"color": "#7c4612",
					"name": "Secondary"
				},
				{
					"slug": "accent",
					"color": "#3B2715",
					"name": "Accent"
				},
				{
					"slug": "light-cream",
					"color": "#FFFAF3",
					"name": "Light Cream"
				},
				{
					"slug": "light-pink",
					"color": "#FFF2F2",
					"name": "Light Pink"
				},
				{
					"slug": "medium-brown",
					"color": "#615245",
					"name": "Medium Brown"
				},
				{
					"slug": "white",
					"color": "#ffffff",
					"name": "White"
				},
				{
					"slug": "black",
					"color": "#000000",
					"name": "Black"
				}
			]
		},
		"typography": {
			"fontFamilies": [
				{
					"fontFamily": "'Marcellus', serif",
					"slug": "marcellus",
					"name": "Marcellus"
				},
				{
					"fontFamily": "'Raleway', sans-serif",
					"slug": "raleway",
					"name": "Raleway"
				}
			],
			"fontSizes": [
				{
					"slug": "small",
					"size": "clamp(0.75rem, 0.7rem + 0.25vw, 0.875rem)",
					"name": "Small"
				},
				{
					"slug": "medium",
					"size": "clamp(0.875rem, 0.8rem + 0.375vw, 1rem)",
					"name": "Medium"
				},
				{
					"slug": "large",
					"size": "clamp(1.25rem, 1rem + 1.25vw, 1.75rem)",
					"name": "Large"
				},
				{
					"slug": "x-large",
					"size": "clamp(1.75rem, 1.25rem + 2.5vw, 2.5rem)",
					"name": "Extra Large"
				},
				{
					"slug": "xx-large",
					"size": "clamp(2.25rem, 1.5rem + 3.75vw, 3.5rem)",
					"name": "XX Large"
				}
			]
		},
		"custom": {
			"breakpoints": {
				"sm": "480px",
				"md": "768px",
				"lg": "1024px",
				"xl": "1200px",
				"xxl": "1400px"
			}
		}
	},
	"styles": {
		"spacing": {
			"padding": {
				"top": "0",
				"right": "0",
				"bottom": "0",
				"left": "0"
			},
			"blockGap": "0"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--raleway)",
			"fontSize": "var(--wp--preset--font-size--medium)",
			"lineHeight": "1.6"
		},
		"elements": {
			"heading": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--marcellus)",
					"lineHeight": "1.3"
				}
			},
			"h1": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--xx-large)"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--x-large)"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--large)"
				}
			}
		}
	}
}
