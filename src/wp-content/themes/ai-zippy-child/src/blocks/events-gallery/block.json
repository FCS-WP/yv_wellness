{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "ai-zippy/events-gallery",
  "version": "1.0.0",
  "title": "Events Gallery",
  "category": "theme",
  "icon": "format-gallery",
  "description": "A masonry-style image gallery with hover overlay text. Add images one by one with captions.",
  "keywords": ["gallery", "events", "images", "masonry", "overlay"],
  "supports": {
    "html": false,
    "align": false,
    "spacing": {
      "margin": true,
      "padding": true
    }
  },
  "attributes": {
    "items": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object"
      }
    },
    "columns": {
      "type": "number",
      "default": 3
    },
    "gap": {
      "type": "number",
      "default": 10
    },
    "overlayColor": {
      "type": "string",
      "default": "rgba(0, 0, 0, 0.7)"
    },
    "overlayTextColor": {
      "type": "string",
      "default": "#ffffff"
    },
    "borderRadius": {
      "type": "number",
      "default": 12
    }
  },
  "textdomain": "ai-zippy-child",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "render": "file:./render.php"
}
