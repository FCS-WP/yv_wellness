    "heading": { "type": "string", "default": "Bridging the gap between <em><u>Science &amp; Vitality</u></em>." },
    "headingColor": { "type": "string", "default": "#3B2715" },
    "description": { "type": "string", "default": "<p>We believe that true beauty is the outward expression of internal health. Our product and device range isn't just about surface-level changes; it's about metabolic health, cellular rejuvenation, and structural integrity.</p><p>By integrating innovative beauty technology with non-invasive treatments, we empower individuals to achieve visible results safely and effectively.</p>" },
    "descriptionColor": { "type": "string", "default": "#615245" },
    "imageUrl": { "type": "string", "default": "" },
