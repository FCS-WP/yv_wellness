{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "ai-zippy/contact-us-form",
  "version": "1.0.0",
  "title": "Contact Us Form",
  "category": "theme",
  "icon": "email",
  "description": "A contact form block with phone/email info cards and a submission form.",
  "keywords": ["contact", "form", "email", "phone"],
  "supports": {
    "html": false,
    "spacing": {
      "margin": true,
      "padding": true
    }
  },
  "attributes": {
    "phone": {
      "type": "string",
      "default": "(+65) 96384686 / 97128668"
    },
    "email": {
      "type": "string",
      "default": "yvwellnesssgp@gmail.com"
    },
    "formTitle": {
      "type": "string",
      "default": "Send us a message"
    },
    "submitText": {
      "type": "string",
      "default": "Send Message"
    },
    "recipientEmail": {
      "type": "string",
      "default": "yvwellnesssgp@gmail.com"
    }
  },
  "textdomain": "ai-zippy-child",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "render": "file:./render.php"
}
